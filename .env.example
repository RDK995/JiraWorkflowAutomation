PORT=3000

# Jira cloud base URL, e.g. https://your-domain.atlassian.net
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Optional aliases used by tools/jira/jira_to_spec.py
JIRA_BASE=
JIRA_EMAIL=
JIRA_TOKEN=

# Optional: validate incoming webhook request header x-jira-webhook-secret
JIRA_WEBHOOK_SECRET=

# Tune transition names if your workflow uses different labels
READY_STATUS="To Do"
IN_PROGRESS_STATUS="In Progress"
IN_REVIEW_STATUS="In Review"

# Codex CLI authentication (used by jira_ticket_to_pr.sh workflow)
CODEX_API_KEY=

# Optional for containerized git/PR workflows
OPENAI_API_KEY=
GITHUB_TOKEN=
GH_TOKEN=
GIT_AUTHOR_NAME=Codex Bot
GIT_AUTHOR_EMAIL=codex-bot@example.com
REQUIRE_GITHUB_AUTH=true
CODEX_BOOTSTRAP_LOGIN=false
CODEX_DEVICE_LOGIN_ON_START=false
CODEX_STATE_DIR=/data/codex
WORKFLOW_BASE_BRANCH=main
WORKFLOW_SCRIPT=./jira_ticket_to_pr.sh
WORKFLOW_TIMEOUT_SECONDS=5400
POST_WORKFLOW_RESULT_TO_JIRA=true
CODEX_EXEC_ARGS=--full-auto

# Optional: expose local webhook through ngrok from inside container
NGROK_ENABLE=false
NGROK_AUTHTOKEN=
NGROK_API_KEY=
NGROK_DOMAIN=
NGROK_PORT=3000
