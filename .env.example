PORT=3000

# AI agent to use for code generation: "codex" or "claude" (default: codex)
AI_AGENT=codex

# Jira cloud base URL, e.g. https://your-domain.atlassian.net
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Optional aliases used by tools/jira/jira_to_spec.py
JIRA_BASE=
JIRA_EMAIL=
JIRA_TOKEN=

# Optional: validate incoming webhook request header x-jira-webhook-secret
JIRA_WEBHOOK_SECRET=

# Optional: verify GitHub webhook signature for merged PR callbacks
GITHUB_WEBHOOK_SECRET=

# Tune transition names if your workflow uses different labels
READY_STATUS="To Do"
IN_PROGRESS_STATUS="In Progress"
IN_REVIEW_STATUS="In Review"
DONE_STATUS="Done"

# Codex CLI authentication (used when AI_AGENT=codex)
CODEX_API_KEY=

# Claude Code authentication controls (used when AI_AGENT=claude)
CLAUDE_BOOTSTRAP_LOGIN=true
CLAUDE_DEVICE_LOGIN_ON_START=true
CLAUDE_STATE_DIR=/data/claude

# Optional for containerized git/PR workflows
OPENAI_API_KEY=
GITHUB_TOKEN=
GH_TOKEN=
GIT_AUTHOR_NAME=PRonto
GIT_AUTHOR_EMAIL=pronto-bot@example.com
REQUIRE_GITHUB_AUTH=true
CODEX_BOOTSTRAP_LOGIN=true
CODEX_DEVICE_LOGIN_ON_START=true
CODEX_STATE_DIR=/data/codex
WORKFLOW_BASE_BRANCH=main
WORKFLOW_SCRIPT=./jira_ticket_to_pr.sh
WORKFLOW_TIMEOUT_SECONDS=5400
POST_WORKFLOW_RESULT_TO_JIRA=true
CODEX_EXEC_ARGS=--full-auto --sandbox danger-full-access

# Claude Code CLI args (used when AI_AGENT=claude)
CLAUDE_EXEC_ARGS=--allowedTools Bash,Edit,Write,Read

# Optional legacy fallback for non-device-auth Claude setups
ANTHROPIC_API_KEY=

# Optional: expose local webhook through ngrok from inside container
NGROK_ENABLE=false
NGROK_AUTHTOKEN=
NGROK_API_KEY=
NGROK_DOMAIN=
NGROK_PORT=3000
