PORT=3000

# Jira cloud base URL, e.g. https://your-domain.atlassian.net
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Optional: validate incoming webhook request header x-jira-webhook-secret
JIRA_WEBHOOK_SECRET=

# Tune transition names if your workflow uses different labels
READY_STATUS=Ready
IN_PROGRESS_STATUS=In Progress

# If you store assignment requirements in a custom field, put the field id here (example: customfield_10042)
ASSIGNMENT_FIELD_ID=

# Codex / OpenAI responses API configuration
CODEX_API_KEY=
CODEX_API_URL=https://api.openai.com/v1/responses
CODEX_MODEL=gpt-5-codex
